# Copy this file to config/.env and fill values before docker compose up.
# Do NOT commit config/.env

# Golden local DB credentials (required)
# Reused by eventstracker and optional local DB containers.
EVENTS_TRACKER_DB_NAME=event-service
EVENTS_TRACKER_DB_USER=change_me_event_db_user
EVENTS_TRACKER_DB_PASSWORD=change_me_event_db_password

# RabbitMQ credentials (required)
RABBITMQ_USERNAME=change_me_rabbit_user
RABBITMQ_PASSWORD=change_me_rabbit_password

# Optional DB name overrides (credentials still use EVENTS_TRACKER_DB_USER/PASSWORD)
RUNS_APP_DB_NAME=runs-app
RUNS_AI_ANALYZER_DB_NAME=runs-ai-analyzer
MYTRACKER_DB_NAME=postgres
SHEDLOCK_DB_NAME=postgres

# EventTracker app-level secrets (required for config-driven placeholders)
EVENT_DOMAIN_USER=change_me_event_domain_user
EVENT_DOMAIN_USER_PASSWORD=change_me_event_domain_password

# Optional: config server container
GIT_URI=
encrypt_key=
username=
pass=
APP_PORT=8888
